# Polymarket endpoints
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# Data collection behavior
POLYMARKET_OUTPUT_DIR=data/raw/polymarket
POLYMARKET_MARKET_LIMIT=20
POLYMARKET_MAX_BOOKS=20
POLYMARKET_TIMEOUT_SEC=10

# Paper trading
POLYMARKET_PAPER_DIR=data/raw/polymarket/paper
PAPER_INITIAL_CASH=1000
PAPER_FEE_BPS=2
PAPER_ORDER_QTY=10
PAPER_HOLD_TICKS=1
PAPER_STRATEGY=periodic
PAPER_RISK_LOSS_LIMIT_PCT=3.0

# Realtime lab
REALTIME_INTERVAL_SEC=20
DASHBOARD_REFRESH_SEC=5
PAPER_USE_MARKET_WS=true
POLYMARKET_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_MARKET_WS_CUSTOM_FEATURE_ENABLED=true

# Strategy race
RACE_CANDIDATES=10
RACE_TOKEN_LIMIT=6
OPENCLAW_ENDPOINT=
OPENCLAW_TIMEOUT_SEC=20
NEWS_SEARCH_API_URL=
NEWS_SEARCH_API_KEY=

# Live guard (default OFF, never turn on before full audit)
LIVE_TRADING_ENABLED=false
LIVE_FORCE_ACK=false
LIVE_MAX_ORDER_USDC=25
POLYMARKET_LIVE_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
